@{
}
@model List<SessionDto>

@{
    ViewData["Title"] = "Mis sesiones";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Mis sesiones activas</h4>
        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    No hay sesiones activas.
                </div>
            }
            else
            {
                <form asp-action="RevokeAllSessions" method="post" class="mb-3">
                    <button type="submit" class="btn btn-danger">
                        Cerrar todas las sesiones
                    </button>
                </form>

                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>ID Sesión</th>
                            <th>Creada</th>
                            <th>Expira</th>
                            <th>Acción</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var session in Model)
                        {
                            <tr>
                                <td>@session.Id</td>
                                <td>@session.CreatedAtUtc.ToLocalTime()</td>
                                <td>@session.ExpiresAtUtc.ToLocalTime()</td>
                                <td>
                                    <form asp-action="RevokeSession" method="post">
                                        <input type="hidden" name="refreshTokenId" value="@session.Id" />

                                        <button type="submit" class="btn btn-warning btn-sm">
                                            Revocar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <a asp-controller="Maintenance" asp-action="Index" class="btn btn-secondary">
                Volver
            </a>

        </div>

    </div>

</div>