<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UAM Front MVC</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fortawesome/fontawesome-free@6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">

        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
            </ul>

            <span class="navbar-text font-weight-bold">
                Programación Avanzada - Frontend MVC
            </span>

            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="form-inline">
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                        </button>
                    </form>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-2">

            <a href="#" class="brand-link">
                <span class="brand-text font-weight-light ml-2">
                    UAM 2026
                </span>
            </a>

            <div class="sidebar">
                <nav class="mt-2">

                    <ul class="nav nav-pills nav-sidebar flex-column"
                        data-widget="treeview"
                        role="menu">

                        <li class="nav-item">
                            <a asp-controller="Maintenance"
                               asp-action="Index"
                               class="nav-link">
                                <i class="nav-icon fas fa-user-graduate"></i>
                                <p>Mantenimiento Estudiantes</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Roles"
                               asp-action="Index"
                               class="nav-link">
                                <i class="nav-icon fas fa-user-shield"></i>
                                <p>Mantenimiento Roles</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Users"
                               asp-action="Index"
                               class="nav-link">
                                <i class="nav-icon fas fa-users"></i>
                                <p>Mantenimiento Usuarios</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Laboratories"
                               asp-action="Index"
                               class="nav-link">
                                <i class="nav-icon fas fa-flask"></i>
                                <p>Mantenimiento Laboratorios</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a asp-controller="Equipment"
                               asp-action="Index"
                               class="nav-link">
                                <i class="nav-icon fas fa-desktop"></i>
                                <p>Mantenimiento Equipos</p>
                            </a>
                        </li>

                    </ul>

                </nav>
            </div>
        </aside>

        <div class="content-wrapper">
            <section class="content pt-3">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.js"></script>

    <script>
        toastr.options = {
        positionClass: 'toast-top-right',
        timeOut: 3500,
        progressBar: true,
        closeButton: true
        };
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>